<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="color-scheme" content="light" />

    <!-- Early connection hints for external CDN domains -->
    <link rel="preconnect" href="https://shared-whale.pstatic.net" />
    <link rel="preconnect" href="https://wcs.naver.net" />
    <link rel="dns-prefetch" href="https://installer-whale.pstatic.net" />
    <link rel="dns-prefetch" href="https://static-whale.pstatic.net" />

    <!-- Fallback values — overridden at runtime by PageMeta component based on locale -->
    <title>NAVER Whale Browser</title>
    <meta name="description" content="클릭은 줄이고 효율은 높이세요. 사이드바, 듀얼 탭, 화상회의 웨일온 등 다양한 기능을 지금 바로 경험하세요." />

    <!-- Favicon -->
    <link rel="icon" href="https://shared-whale.pstatic.net/favicon/icon.png" type="image/png" />
    <link rel="apple-touch-icon" href="https://shared-whale.pstatic.net/favicon/icon.png" />
    <link rel="apple-touch-icon" href="https://shared-whale.pstatic.net/favicon/icon180.png" sizes="180x180" />
    <link rel="apple-touch-icon" href="https://shared-whale.pstatic.net/favicon/icon256.png" sizes="256x256" />
    <link rel="apple-touch-icon" href="https://shared-whale.pstatic.net/favicon/icon512.png" sizes="512x512" />

    <!-- Open Graph (static properties — locale-dependent ones set by PageMeta) -->
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://whale.naver.com/og/og_image_rectangle.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://whale.naver.com/og/og_image_rectangle.png" />

