    <!-- Kakao Pixel (production only) -->
    <script>
      if (location.hostname === 'whale.naver.com') {
        var s = document.createElement('script');
        s.type = 'text/javascript'; s.charset = 'UTF-8'; s.defer = true;
        s.src = '//t1.daumcdn.net/kas/static/kp.js';
        document.head.appendChild(s);
      }
    </script>

    <!-- LCS (Naver Log Collection System) — init on all deployment phases (DEV/TEST/REAL) -->
    <script>
      if (/^(dev\.|test\.)?whale\.naver\.com$/.test(location.hostname)) {
        window.lcs_SerName = 'lcs.naver.com';
      }
    </script>
    <script defer src="/vendor/lcslog.v0.14.0.js"></script>

    <!-- nClicks: ccsrv is read by the bundled SDK (src/vendor/nclicks.js) — init on all phases -->
    <script>
      if (/^(dev\.|test\.)?whale\.naver\.com$/.test(location.hostname)) {
        window.ccsrv = 'cc.naver.com';
      }
    </script>
    <script type="module" crossorigin src="https://shared-whale.pstatic.net/home2/assets/index-BwquERjw.js"></script>
    <link rel="stylesheet" crossorigin href="https://shared-whale.pstatic.net/home2/assets/index-C9WkbesE.css">
